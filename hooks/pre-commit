#!/usr/bin/env bash
#
# git pre-commit hook
#
# 활성화: 프로젝트 루트에서 한 번만 실행
#   git config core.hooksPath hooks
#
# 이후 `git commit` 이 실행되면 scripts/test-content.sh 로 콘텐츠 검증.
# 실패 시 exit 1 로 커밋 중단.

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
exec bash "$REPO_ROOT/scripts/test-content.sh"
